MOCK_USD_ADDR=
MOCK_TKA_ADDR=
MOCK_TKB_ADDR=
MOCK_ORACLE_ADDR=
MOCK_DEX_ADDR=

# Runtime tuning (seconds -> ms)
CYCLE_MS=15000
HTTP_PORT=7777
